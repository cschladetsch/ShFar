#!/usr/bin/env bash

set -euo pipefail

VERSION="1.0.0"

usage() {
    cat <<USAGE
Usage: far [OPTIONS] <root> [glob] <find> [replace]

Find and replace text across files matching a filename glob.

Arguments:
  root      Directory to search in (use . for current directory)
  glob      Filename glob pattern (default: '*')
  find      Text or regex to search for
  replace   Replacement text (omit to list matching files only)

Options:
  -y        Skip confirmation prompt
  -n        Dry run -- show matching files only, make no changes
  -b        Create .bak backups before modifying (default: no backups)
  -v        Show version and exit
  -h        Show this help message

Examples:
  far . 'Foo'                            # list all files containing 'Foo'
  far . '*.cpp' 'Foo'                    # list .cpp files containing 'Foo'
  far . '*.cpp' 'OldClass' 'NewClass'    # find and replace
  far ./src '*.cpp' 'OldClass' 'NewClass'
  far -y . '*.txt' 'foo' 'bar'
  far -n . '*.h' 'TODO' 'FIXME'
  far -b . '*.cpp' 'OldClass' 'NewClass'
  far . '*.{cpp,h}' '// -- (.*) -+$' '// \1'

Exit codes:
  0  Success
  1  Bad arguments
  2  No matching files found
  3  User aborted
USAGE
    exit "${1:-0}"
}

AUTO_YES=0
DRY_RUN=0
BACKUP=0
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

while getopts "ynbvh" opt; do
    case $opt in
        y) AUTO_YES=1 ;;
        n) DRY_RUN=1 ;;
        b) BACKUP=1 ;;
        v) echo "far $VERSION"; exit 0 ;;
        h) usage 0 ;;
        *) usage 1 ;;
    esac
done
shift $((OPTIND - 1))

if [[ $# -lt 2 ]]; then
    echo "Error: missing required arguments" >&2
    usage 1
fi

ROOT="$1"

if [[ ! -d "$ROOT" ]]; then
    echo "Error: '$ROOT' is not a directory" >&2
    exit 1
fi

# determine glob, find, replace based on arg count
# far <root> <find>
# far <root> <glob> <find>
# far <root> <glob> <find> <replace>
if [[ $# -eq 2 ]]; then
    GLOB='*'
    FIND="$2"
    REPLACE=""
elif [[ $# -eq 3 ]]; then
    # ambiguous: is arg2 a glob or a find term?
    # treat as glob if it contains a wildcard or dot, else as find
    if [[ "$2" == *'*'* || "$2" == *'.'* ]]; then
        GLOB="$2"
        FIND="$3"
        REPLACE=""
    else
        GLOB='*'
        FIND="$2"
        REPLACE="$3"
    fi
else
    GLOB="$2"
    FIND="$3"
    REPLACE="$4"
fi

normalize_sed_fragment() {
    local fragment="$1"
    # Accept fully wrapped /.../ input.
    if [[ "$fragment" == /*/ && ${#fragment} -ge 2 ]]; then
        printf '%s\n' "${fragment:1:${#fragment}-2}"
        return
    fi
    # Tolerate a leading sed delimiter in user input such as /foo or /\/bar.
    if [[ "$fragment" == /* ]]; then
        fragment="${fragment:1}"
    fi
    # Escaped slashes were only needed with the old / delimiter.
    fragment=${fragment//\\\//\/}
    printf '%s\n' "$fragment"
}

escape_sed_replacement() {
    local replacement="$1"
    replacement=${replacement//&/\\&}
    replacement=${replacement//|/\\|}
    printf '%s\n' "$replacement"
}

find_fastsed() {
    if [[ -n "${FASTSED_BIN:-}" && -x "${FASTSED_BIN}" ]]; then
        printf '%s\n' "${FASTSED_BIN}"
        return
    fi
    if [[ -x "${SCRIPT_DIR}/CppSed/Bin/fastsed" ]]; then
        printf '%s\n' "${SCRIPT_DIR}/CppSed/Bin/fastsed"
        return
    fi
    if [[ -x "${SCRIPT_DIR}/CppSed/.fastsed-build/fastsed" ]]; then
        printf '%s\n' "${SCRIPT_DIR}/CppSed/.fastsed-build/fastsed"
        return
    fi
    if command -v fsed >/dev/null 2>&1; then
        command -v fsed
        return
    fi
    if command -v fastsed >/dev/null 2>&1; then
        command -v fastsed
        return
    fi
    return 1
}

SEARCH_PATTERN=$(normalize_sed_fragment "$FIND")
SAFE_REPLACE=$(escape_sed_replacement "$(normalize_sed_fragment "$REPLACE")")
FASTSED_BIN="$(find_fastsed || true)"

mapfile -d '' FILES < <(fd -0 -g "$GLOB" "$ROOT" --type f)
MATCHES=()

if [[ ${#FILES[@]} -gt 0 ]]; then
    while IFS= read -r -d '' match; do
        MATCHES+=("$match")
    done < <(printf '%s\0' "${FILES[@]}" | xargs -0 rg -l -0 -- "$SEARCH_PATTERN" 2>/dev/null || true)
fi

if [[ ${#MATCHES[@]} -eq 0 ]]; then
    echo "No files found matching glob '$GLOB' containing '$FIND' under '$ROOT'"
    exit 2
fi

# search-only mode
if [[ -z "$REPLACE" || $DRY_RUN -eq 1 ]]; then
    echo "Files containing '$FIND':"
    printf '  %s\n' "${MATCHES[@]}"
    [[ $DRY_RUN -eq 1 ]] && echo "Dry run -- no changes made."
    exit 0
fi

echo "Files to be modified:"
printf '  %s\n' "${MATCHES[@]}"
echo

if [[ $AUTO_YES -eq 0 ]]; then
    read -rp "Replace '$FIND' with '$REPLACE'? [y/N] " confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || exit 3
fi

if [[ $BACKUP -eq 1 ]]; then
    if [[ -n "$FASTSED_BIN" ]]; then
        printf '%s\0' "${MATCHES[@]}" | xargs -0 "$FASTSED_BIN" -E --inplace=.bak "s|$SEARCH_PATTERN|$SAFE_REPLACE|g" >/dev/null
    else
        printf '%s\0' "${MATCHES[@]}" | xargs -0 sed -E -i.bak "s|$SEARCH_PATTERN|$SAFE_REPLACE|g"
    fi
    echo "Done. Backups written as *.bak"
else
    if [[ -n "$FASTSED_BIN" ]]; then
        printf '%s\0' "${MATCHES[@]}" | xargs -0 "$FASTSED_BIN" -E --inplace=$'\x01' "s|$SEARCH_PATTERN|$SAFE_REPLACE|g" >/dev/null
    else
        printf '%s\0' "${MATCHES[@]}" | xargs -0 sed -E -i "s|$SEARCH_PATTERN|$SAFE_REPLACE|g"
    fi
    echo "Done."
fi
