#!/usr/bin/env bash

set -euo pipefail

VERSION="1.0.0"

usage() {
    cat <<USAGE
Usage: far [OPTIONS] <root> [glob] <find> [replace]

Find and replace text across files matching a filename glob.

Arguments:
  root      Directory to search in (use . for current directory)
  glob      Filename glob pattern (default: '*')
  find      Text or regex to search for
  replace   Replacement text (omit to list matching files only)

Options:
  -y        Skip confirmation prompt
  -n        Dry run -- show matching files only, make no changes
  -b        Create .bak backups before modifying (default: no backups)
  -v        Show version and exit
  -h        Show this help message

Examples:
  far . 'Foo'                            # list all files containing 'Foo'
  far . '*.cpp' 'Foo'                    # list .cpp files containing 'Foo'
  far . '*.cpp' 'OldClass' 'NewClass'    # find and replace
  far ./src '*.cpp' 'OldClass' 'NewClass'
  far -y . '*.txt' 'foo' 'bar'
  far -n . '*.h' 'TODO' 'FIXME'
  far -b . '*.cpp' 'OldClass' 'NewClass'

Exit codes:
  0  Success
  1  Bad arguments
  2  No matching files found
  3  User aborted
USAGE
    exit "${1:-0}"
}

AUTO_YES=0
DRY_RUN=0
BACKUP=0

while getopts "ynbvh" opt; do
    case $opt in
        y) AUTO_YES=1 ;;
        n) DRY_RUN=1 ;;
        b) BACKUP=1 ;;
        v) echo "far $VERSION"; exit 0 ;;
        h) usage 0 ;;
        *) usage 1 ;;
    esac
done
shift $((OPTIND - 1))

if [[ $# -lt 2 ]]; then
    echo "Error: missing required arguments" >&2
    usage 1
fi

ROOT="$1"

if [[ ! -d "$ROOT" ]]; then
    echo "Error: '$ROOT' is not a directory" >&2
    exit 1
fi

# determine glob, find, replace based on arg count
# far <root> <find>
# far <root> <glob> <find>
# far <root> <glob> <find> <replace>
if [[ $# -eq 2 ]]; then
    GLOB='*'
    FIND="$2"
    REPLACE=""
elif [[ $# -eq 3 ]]; then
    # ambiguous: is arg2 a glob or a find term?
    # treat as glob if it contains a wildcard or dot, else as find
    if [[ "$2" == *'*'* || "$2" == *'.'* ]]; then
        GLOB="$2"
        FIND="$3"
        REPLACE=""
    else
        GLOB='*'
        FIND="$2"
        REPLACE="$3"
    fi
else
    GLOB="$2"
    FIND="$3"
    REPLACE="$4"
fi

# fd matches by filename glob, rg filters to those containing FIND
MATCHES=$(fd -g "$GLOB" "$ROOT" --type f | xargs rg -l "$FIND" 2>/dev/null || true)

if [[ -z "$MATCHES" ]]; then
    echo "No files found matching glob '$GLOB' containing '$FIND' under '$ROOT'"
    exit 2
fi

# search-only mode
if [[ -z "$REPLACE" || $DRY_RUN -eq 1 ]]; then
    echo "Files containing '$FIND':"
    echo "$MATCHES" | sed 's/^/  /'
    [[ $DRY_RUN -eq 1 ]] && echo "Dry run -- no changes made."
    exit 0
fi

echo "Files to be modified:"
echo "$MATCHES" | sed 's/^/  /'
echo

if [[ $AUTO_YES -eq 0 ]]; then
    read -rp "Replace '$FIND' with '$REPLACE'? [y/N] " confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || exit 3
fi

if [[ $BACKUP -eq 1 ]]; then
    echo "$MATCHES" | xargs sed -i.bak "s/$FIND/$REPLACE/g"
    echo "Done. Backups written as *.bak"
else
    echo "$MATCHES" | xargs sed -i "s/$FIND/$REPLACE/g"
    echo "Done."
fi
